# ─── Qdrant (free cloud tier at cloud.qdrant.io) ──────────────────
QDRANT_URL=qdrant_url_goes_here
QDRANT_API_KEY=qdrant_api_key_goes_here
QDRANT_COLLECTION=devvoice_v2
# ─── Jina AI (FREE embeddings — sign up at jina.ai) ──────────────
# Free tier gives 1M tokens/month — more than enough for a hackathon
JINA_API_KEY=jina_api_key_goes_here
# ─── Vapi (voice + LLM — uses your Vapi credits) ─────────────────
# Get these from: https://dashboard.vapi.ai
GROQ_API_KEY=groq_api_key_goes_here
VAPI_PUBLIC_KEY=vapi_public_key_goes_here
VAPI_ASSISTANT_ID=vapi_assistant_id_goes_here
VAPI_PRIVATE_KEY=vapi_private_key_goes_here

# ─── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Your public URL (set after running ngrok) ────────────────────
# Run: ngrok http 3000
# Then paste the https URL here and set it in Vapi dashboard too
PUBLIC_URL=public_url_goes_here
# ─── REMOVED (no longer needed) ──────────────────────────────────
# OPENAI_API_KEY   ← replaced by Jina AI (free)
# ANTHROPIC_API_KEY ← replaced by Vapi's built-in LLM
